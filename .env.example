# Required for the contact form API route.
# Get a Resend API key from https://resend.com/api-keys.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxx

# The verified sender address/domain configured in Resend.
# Example: ScaleVeda <hello@your-verified-domain.com>
CONTACT_FROM_EMAIL="ScaleVeda <hello@your-verified-domain.com>"

# Where contact inquiries should be delivered.
CONTACT_TO_EMAIL=yeshthalapaneni@gmail.com

# Optional: canonical site URL used by metadata/Open Graph tags.
NEXT_PUBLIC_SITE_URL=https://scaleveda.com
